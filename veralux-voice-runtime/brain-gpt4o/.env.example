# OpenAI cloud: set API key and leave OPENAI_BASE_URL unset.
OPENAI_API_KEY=sk-...

# Local vLLM (OpenAI-compatible): point at the server and use a dummy key.
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# OPENAI_API_KEY=EMPTY
# OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ

# Optional: model when using OpenAI (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional: port (default: 3001)
# PORT=3001
