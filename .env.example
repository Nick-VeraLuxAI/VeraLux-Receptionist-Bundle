# =============================================================================
# Veralux Receptionist - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values below.
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Deployment Version & Registry
# -----------------------------------------------------------------------------
# Pin to a specific version for reproducible deployments
# Use: openssl rand -hex 4  to generate a short tag, or use semver (e.g., 0.1.0)
VERSION=0.1.0
REGISTRY=ghcr.io/nick-veraluxai

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=veralux
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=veralux

# -----------------------------------------------------------------------------
# Application Security
# -----------------------------------------------------------------------------
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET

# Master admin API key (used for admin panel access and inter-service auth)
# Generate: openssl rand -hex 32
ADMIN_API_KEY=CHANGE_ME_GENERATE_SECURE_KEY

# Installer credentials (used by install.sh "Admin Setup" mode)
# Username defaults to "VeraLux", password defaults to ADMIN_API_KEY
INSTALLER_USERNAME=VeraLux
# INSTALLER_PASSWORD=  (leave unset to use ADMIN_API_KEY)

# Encryption key for tenant secrets stored in DB
# Generate: openssl rand -hex 24
SECRET_ENCRYPTION_KEY=CHANGE_ME_GENERATE_SECURE_KEY
SECRET_MANAGER=db

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# Base URL where the control panel is accessible
BASE_URL=http://localhost:4000

# Public URL where the runtime is accessible (for Telnyx webhooks)
PUBLIC_BASE_URL=https://your-domain.com
# Public URL for audio file access
AUDIO_PUBLIC_BASE_URL=https://your-domain.com/audio

# CORS origins allowed to access the admin panel (comma-separated)
ADMIN_ALLOWED_ORIGINS=http://localhost:4000

# Max wait (ms) for admin TTS preview to call the upstream TTS service (default 90000, max 300000)
# TTS_PREVIEW_FETCH_TIMEOUT_MS=90000

# -----------------------------------------------------------------------------
# Port Configuration (change if ports conflict)
# -----------------------------------------------------------------------------
CONTROL_PORT=4000
RUNTIME_PORT=4001
# POSTGRES_PORT=5432  # Uncomment to expose for debugging

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Telnyx Configuration (Required for Voice Runtime)
# Get these from https://portal.telnyx.com
# -----------------------------------------------------------------------------
TELNYX_API_KEY=CHANGE_ME
TELNYX_PUBLIC_KEY=CHANGE_ME
TELNYX_PHONE_NUMBER=

# Webhook signature verification (MUST be true in production)
TELNYX_VERIFY_SIGNATURES=true

# Audio codecs accepted from Telnyx (AMR-WB provides better quality)
TELNYX_ACCEPT_CODECS=PCMU,AMR-WB
TELNYX_AMRWB_DECODE=true

# TTS output sample rate for PSTN playback
# 24000 = let Telnyx downsample from 24kHz (best quality)
# 16000 = pre-downsample to 16kHz (lower latency)
PLAYBACK_PSTN_SAMPLE_RATE=24000

# -----------------------------------------------------------------------------
# LLM Configuration (default: openai)
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai
OPENAI_API_KEY=CHANGE_ME
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Voice brain — local Qwen (optional profile: llm)
# -----------------------------------------------------------------------------
# Start vLLM + brain: docker compose --profile llm up -d vllm-qwen brain
# Then point the voice runtime at the brain container (same Docker network):
# BRAIN_USE_LOCAL=false
# BRAIN_URL=http://brain:3001
# GPU for vLLM only (e.g. 1 = second GPU when 0 is used for TTS): VLLM_GPU_IDS=1
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
# VLLM_PORT=8000
# Receptionist-oriented defaults in compose: ~24 concurrent seqs, ~60% VRAM — not 256 parallel chats.
# Lowering vLLM on GPU 1 does not free VRAM for Chatterbox on GPU 0 unless you map both to the same GPU.
# VLLM_GPU_MEMORY_UTILIZATION=0.6
# VLLM_MAX_NUM_SEQS=24
# If vLLM exits with "Free memory ... less than desired GPU memory utilization", lower utilization further.
# VLLM_IMAGE=vllm/vllm-openai:cu130-nightly-x86_64
# VLLM_OPENAI_API_KEY=EMPTY

# -----------------------------------------------------------------------------
# Stripe (optional — enables payment processing)
# Get keys from https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# TTS Configuration
# -----------------------------------------------------------------------------
# TTS engine: coqui_xtts (default), kokoro_http, or qwen3_tts_http
# For qwen3_tts_http use ./deploy.sh up (or compose --profile gpu|cpu) so qwen3-tts-* starts; plain compose up omits it.
TTS_MODE=coqui_xtts
KOKORO_URL=http://kokoro:7001
XTTS_URL=http://xtts:7002
COQUI_XTTS_URL=http://xtts:7002/tts

# Chatterbox (docker compose: chatterbox-gpu, alias chatterbox). Preview + chatterbox_http TTS.
CHATTERBOX_URL=http://chatterbox:7005
CHATTERBOX_VARIANT=turbo
# cuda (default) or cpu — image uses PyTorch 2.7+cu128 for Blackwell; cpu for driverless / debugging.
CHATTERBOX_DEVICE=cuda
# Runtime: when true + turbo, voice-runtime uses POST /tts/stream and merges segment WAVs (long replies).
CHATTERBOX_STREAMING=false

# Chatterbox container (chatterbox-gpu): Gunicorn workers = concurrent model lanes; speaker cache; warmup.
# CHATTERBOX_GUNICORN_WORKERS=2
# CHATTERBOX_SPEAKER_CACHE_DIR=/tmp/chatterbox_speaker_cache
# CHATTERBOX_PRELOAD_SPEAKER_URLS=https://example.com/ref.wav
# CHATTERBOX_STREAM_MAX_SEGMENTS=8

# Hugging Face — required for Chatterbox (chatterbox-gpu) to download gated weights.
# Read token: https://huggingface.co/settings/tokens
HF_TOKEN=

# -----------------------------------------------------------------------------
# Media/Audio Configuration
# -----------------------------------------------------------------------------
# Token for authenticating media stream connections
MEDIA_STREAM_TOKEN=CHANGE_ME_GENERATE_SECURE_TOKEN
AUDIO_STORAGE_DIR=/app/audio

# -----------------------------------------------------------------------------
# Speech-to-Text Settings
# -----------------------------------------------------------------------------
STT_CHUNK_MS=100
STT_SILENCE_MS=700
# Tier-1 dynamic finalize: minimum speech before silence can finalize (defaults 280ms / 8000 bytes in compose).
# Raise to reduce rapid successive finals; lower if users get cut off.
STT_MIN_SPEECH_MS_TO_FINALIZE=280
STT_MIN_SPEECH_BYTES_TO_FINALIZE=8000
# Acoustic echo cancellation (SpeexDSP). Default on; Docker runtime image includes libspeexdsp1.
STT_AEC_ENABLED=true
# JSON snapshots: levels, gates, dedupe, timing (event stt_pipeline_diag). 0=off. Typical: 2500
STT_PIPELINE_DIAG_INTERVAL_MS=0
STT_PIPELINE_DIAG_ON_PLAYBACK=true
DEAD_AIR_MS=10000
# Empty/error STT: Whisper retries + spoken reprompt (pipe-separated phrases optional)
STT_UNCLEAR_REPROMPT_ENABLED=true
STT_EMPTY_FINAL_EXTRA_TRIES=1
STT_FINAL_ERROR_EXTRA_TRIES=1
STT_FINAL_RETRY_BACKOFF_MS=180
STT_UNCLEAR_REPROMPT_MAX_PER_CALL=8
STT_UNCLEAR_REPROMPT_COOLDOWN_MS=2200
# STT_UNCLEAR_REPROMPT_PHRASES=Sorry, could you repeat that?|I didn't catch that — one more time?
# STT_UNCLEAR_MIN_LETTERS=0
# Inbound PCM attenuation before AEC/STT (negative dB only). Slightly more than -3 can reduce echo/clip before AEC.
STT_RX_HEADROOM_DB=-4
# After TTS: widen min/max grace so STT buffering starts later; reduces assistant tail in user utterances.
STT_POST_PLAYBACK_GRACE_MS=900
STT_POST_PLAYBACK_GRACE_MIN_MS=400
STT_POST_PLAYBACK_GRACE_MAX_MS=1100
# Identical RX frame replay guard before ChunkedSTT (see veralux-voice-runtime/docs/troubleshooting.md).
STT_RX_POSTPROCESS_ENABLED=true
STT_RX_DEDUPE_WINDOW=48
# Near-duplicate Whisper finals (same utterance twice) — fewer duplicate bot replies.
STT_TRANSCRIPT_DEDUPE_ENABLED=true
STT_TRANSCRIPT_DEDUPE_WINDOW_MS=2200
STT_TRANSCRIPT_DEDUPE_SIMILARITY=0.9
# Telnyx sequence gaps: metrics + throttled warn (possible dropped media).
MEDIA_SEQ_GAP_LOG_MIN=3
# Whisper client: TCP keepalive (lower tail latency on hot calls).
WHISPER_HTTP_KEEPALIVE=true
WHISPER_HTTP_MAX_CONNECTIONS=8

# STT WAV debug — files land in STT_DEBUG_DIR (default: /app/audio/stt-debug inside the runtime container; same path is on the audio Docker volume). Disable after diagnosis.
STT_DEBUG_DIR=/app/audio/stt-debug
# ~1.25s PCM16 after assistant playback ends (post-decode listen path)
STT_DEBUG_DUMP_RX_WAV=false
# Call end: stereo WAV L=near / R=AEC-out (20 ms aligned). scripts/analyze_stt_wav.py --channel all
STT_DEBUG_AEC_NEAR_OUT_WAV=false
STT_DEBUG_AEC_TAP_MAX_MS=8000
# Exact WAV bytes POSTed to Whisper (partial + final); stt_whisper_wav_dumped in logs
STT_DEBUG_DUMP_WHISPER_WAVS=false
# Codec decode: rolling chunks + 400ms windows under STT_DEBUG_DIR/<call_control_id>/
STT_DEBUG_DUMP_PCM16=false
# Speex AEC far-end reference frames (optional)
STT_DEBUG_DUMP_FAR_END_REF=false
# Pre-Whisper normalize/dedupe (can garble PSTN audio if mis-tuned). Prefer false unless you need it.
STT_PREWHISPER_GATE=false
# Pre-Whisper PCM frame dedupe (default 32 in code). 0 disables.
# STT_PREWHISPER_DEDUPE_WINDOW=32
# int16 peak threshold for silence-aware dedupe (default 280 in code). 0 = legacy.
# STT_PREWHISPER_DEDUPE_MIN_PEAK_ABS=280
STT_PREWHISPER_DUMP_DIR=/app/audio/stt-debug
STT_PREWHISPER_DUMP_FIRST_N=10

# -----------------------------------------------------------------------------
# Rate Limiting / Capacity
# -----------------------------------------------------------------------------
GLOBAL_CONCURRENCY_CAP=100
TENANT_CONCURRENCY_CAP_DEFAULT=10
TENANT_CALLS_PER_MIN_CAP_DEFAULT=60
CAPACITY_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# GPU Services Configuration (Optional)
# Enable GPU services with: docker compose --profile gpu up
# -----------------------------------------------------------------------------

# Whisper (Speech-to-Text)
WHISPER_PORT=9000
# CPU profile: legacy alias (maps to WHISPER_MODEL if WHISPER_MODEL unset)
WHISPER_MODEL_SIZE=small
# GPU profile (Dockerfile.whisper.gpu): faster-whisper model id, e.g. large-v3, distil-large-v3, small
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
# Physical GPU index (or comma-separated list). Compose uses device_ids so each service maps to the intended
# card (see docker-compose.yml). Validated 2×GPU split: Chatterbox Turbo workers on GPU 0; Whisper + vLLM on GPU 1
# (avoids STT/TTS contention on one card). Alternate: colocate Whisper + Chatterbox on 0 and vLLM on 1.
# Recreate whisper after changing WHISPER_GPU_IDS: WHISPER_GPU_IDS=1 docker compose --profile gpu up -d whisper-gpu
WHISPER_GPU_IDS=1
CHATTERBOX_GPU_IDS=0

# Kokoro (Voice Synthesis)
KOKORO_PORT=7001
KOKORO_VOICE_ID=default
# GPU profile: kokoro-gpu uses Dockerfile.kokoro.gpu (onnxruntime-gpu + KOKORO_DEVICE=cuda).
# Second GPU: e.g. KOKORO_GPU_IDS=1
KOKORO_GPU_IDS=0
# KOKORO_DEVICE=cuda

# XTTS (Text-to-Speech)
XTTS_PORT=7002
XTTS_LANGUAGE=en
# GPU profile (xtts-gpu): must be true for Coqui to use CUDA (see docker-compose environment).
# XTTS_USE_GPU=true
# Second GPU: XTTS_GPU_IDS=1 (default 0). Align with NVIDIA_VISIBLE_DEVICES in compose.
XTTS_GPU_IDS=0

# TTS latency benchmark (scripts/benchmark-tts-backends.ts): abort if Kokoro/XTTS/Chatterbox/Qwen3
# /health shows CPU. Use: npm run benchmark:tts-gpu -- /path/to.wav (after compose --profile gpu up).
# TTS_BENCH_REQUIRE_GPU=true
# TTS_BENCH_SKIP_GPU_PREFLIGHT=true

# -----------------------------------------------------------------------------
# Tunnel Configuration (Optional)
# Use ONE of: Cloudflare (recommended) or ngrok (dev/testing)
# -----------------------------------------------------------------------------

# Ngrok (for tunneling - get token from https://dashboard.ngrok.com)
NGROK_AUTHTOKEN=

# Cloudflare Tunnel (recommended - requires config in ./cloudflared/)
# Go to: Zero Trust → Networks → Tunnels → Create tunnel
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARED_TAG=

# Ngrok image tag (pin explicitly, e.g. 3.13.0)
NGROK_TAG=

# -----------------------------------------------------------------------------
# SMTP Configuration (Optional — enables workflow email actions)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@veralux.ai
